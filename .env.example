# Required: Binance API credentials.
# Testnet keys: https://testnet.binance.vision/
# Live keys: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Live-mode opt-in. Default (unset / anything except exactly "true") = TESTNET.
# Only set this to "true" once you have verified the bot on testnet AND you
# are ready to risk real funds. The bot will print a 5-second warning banner
# before the first tick when running in live mode.
BINANCE_LIVE=false

# Set to "true" if your account holds BTC unrelated to this bot (e.g.,
# long-term holdings). The bot will then ignore that BTC at startup rather
# than refusing to run. The bot will NOT manage that BTC.
BINANCE_IGNORE_ORPHAN_BTC=false

# Set to "true" to emit structured JSON logs suitable for production log
# aggregators (Datadog, Loki, etc.). Default (unset / "false") emits colored,
# human-readable single-line logs to the terminal.
LOG_JSON=false
